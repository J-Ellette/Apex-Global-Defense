# ── Map tile server ───────────────────────────────────────────────────────────
VITE_TILE_SERVER=http://localhost:8081

# ── Feature flags ─────────────────────────────────────────────────────────────
# Set to "true" to disable external network calls (air-gap mode)
VITE_AIRGAP=false
