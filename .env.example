# Apex Global Defense — root .env.example
# Copy this file to .env and fill in real values before starting services.
# NEVER commit a .env file with real secrets to version control.
#
# Used by docker-compose.dev.yml and docker-compose.test.yml via ${VAR:-default}.

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=agd_dev
POSTGRES_USER=agd
POSTGRES_PASSWORD=change-me-in-production

# ── JWT / Auth ───────────────────────────────────────────────────────────────
# Minimum 32 random characters for HS256.  Use a cryptographically random value.
JWT_SECRET=change-me-in-production

# ── Keycloak ─────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-in-production

# ── Redis ────────────────────────────────────────────────────────────────────
# Leave blank for unauthenticated (dev default); set for production.
REDIS_PASSWORD=

# ── Simulation engine ────────────────────────────────────────────────────────
USE_GRPC_SIM_ENGINE=true
SIM_ENGINE_GRPC_ADDR=sim-engine:50051

# ── AI providers (optional) ──────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434

# ── Observability (optional) ─────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
